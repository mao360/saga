# Цель нагрузки. Скрипты гоняются с локальной машины, приложение — на VPS.
# По docs/deploy.md наружу открыт только order:8080, и только для IP генератора,
# так что при смене домашнего IP firewall надо обновить — иначе тест упрётся в
# закрытый порт, и это будет выглядеть как отказ сервиса.
ORDER_BASE_URL=http://VPS_IP:8080
ORDER_PATH=/orders
HEALTH_PATH=/healthz

# Каталог. Zipf-распределение по SKU_COUNT товарам: доля обращений к i-му
# товару ~ 1/i^ZIPF_S. s=1.0 — обычный длинный хвост; s=0 сделает выборку
# равномерной, s=2 сожмёт трафик в верхушку каталога и усилит contention.
SKU_COUNT=200
ACCOUNT_COUNT=200
ZIPF_S=1.0

# Флеш-сейл: доля трафика, принудительно уходящая в один товар (orders-hotkey).
HOT_SKU=sku-1
HOT_SHARE=1.0

# Совместимость со старыми сценариями (smoke/ramp/soak/arrival) — они бьют
# в один ключ намеренно.
SKU=sku-1
ACCOUNT_ID=acc-1
AMOUNT=100
QTY=1

REQUEST_TIMEOUT=15s
SLEEP_SECONDS=0.1

# Смешанный профиль: общая скорость и доли потоков.
RATE=60
DURATION=5m
SHARE_HAPPY=0.8
SHARE_NO_FUNDS=0.1
SHARE_OUT_OF_STOCK=0.05
SHARE_DUPLICATE=0.05
BASELINE_RATE=2

# Запас VU. По закону Литтла нужное число VU = rps x время ответа, поэтому при
# деградации сервиса потребность растёт кратно. Упереться в собственный
# генератор — худший исход: k6 предупредит про dropped iterations, и цифры
# throughput перестанут описывать сервер.
PREALLOCATED_VUS=50
MAX_VUS=300