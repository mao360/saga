SAGA_NETWORK=

# Bind address for Prometheus / Grafana / cAdvisor / kafka-exporter ports.
# Local dev: 0.0.0.0 (default). On a public VPS set 127.0.0.1 and reach
# Grafana via an SSH tunnel.
ADMIN_BIND=
# On a public VPS: disable anonymous Grafana (false) and set a strong password.
GF_AUTH_ANONYMOUS_ENABLED=
