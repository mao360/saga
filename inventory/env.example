HTTP_PORT=8082
APP_CONFIG_PATH=internal/platform/config/config.yaml

KAFKA_BROKERS=kafka:9092
KAFKA_CLIENT_ID=inventory-service
KAFKA_GROUP_ID=inventory-service-v1

KAFKA_TOPIC_ORDER_EVENTS=saga.order.events
KAFKA_TOPIC_PAYMENT_EVENTS=saga.payment.events
KAFKA_TOPIC_INVENTORY_EVENTS=saga.inventory.events
KAFKA_TOPIC_COMMANDS=saga.commands
KAFKA_TOPIC_DLQ=saga.dlq

POSTGRES_USER=inventory
POSTGRES_PASSWORD=inventory
POSTGRES_DB=inventory
POSTGRES_PORT=5434
POSTGRES_HEALTHCHECK_TIMEOUT=3s
KAFKA_HEALTHCHECK_TIMEOUT=5s

DATABASE_CONNECT_TIMEOUT=10s
SHUTDOWN_TIMEOUT=5s

DATABASE_DSN=postgres://inventory:inventory@postgres-inventory:5432/inventory?sslmode=disable
